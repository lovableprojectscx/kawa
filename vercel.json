{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!assets/|favicon.ico|robots.txt|kawa-logo.png|manifest.json|icon-.*\\.png|icon.svg|placeholder.svg|sw.js).*)", "destination": "/index.html" }
  ]
}
